   "source": [
    "# split datasets for train/test FOR TF-IDF DATASET\n",
    "train_tfidf = sexism_df_tfidf[sexism_df_tfidf['split_original'] == 'train']\n",
    "test_tfidf = sexism_df_tfidf[sexism_df_tfidf['split_original'] == 'test']\n",
    "\n",
    "# split datasets into inputs and ouputs for training set\n",
    "y_train_tfidf = train_tfidf['label_original']\n",
    "x_train_tfidf = train_tfidf.drop(['text_original', 'label_original', 'split_original'], axis=1)\n",
    "\n",
    "# split datasets into inputs and ouputs for test set\n",
    "y_test_tfidf = test_tfidf['label_original']\n",
    "x_test_tfidf = test_tfidf.drop(['text_original', 'label_original', 'split_original'], axis=1)\n",
    "\n",
    "\n",
    "\n",
    "'''\n",
    "print(f\"shape of x_train = {x_train_tfidf.shape}\")\n",
    "print(f\"shape of y_train = {y_train_tfidf.shape}\")\n",
    "\n",
    "print(f\"shape of x_train = {x_test_tfidf.shape}\")\n",
    "print(f\"shape of y_train = {y_test_tfidf.shape}\")\n",
    "'''\n",
    "x_train_tfidf.head()"
   ]
