   "source": [
    "# feature engineer data using Word2Vec\n",
    "\n",
    "# copy sexism_df dataset\n",
    "sexism_df_w2v = sexism_df.copy()\n",
    "sexism_df_w2v['text'] = sexism_df_w2v['text'].apply(lambda x: word_tokenize(x))\n",
    "\n",
    "# vectorize data\n",
    "w2v = Word2Vec(sentences=sexism_df_w2v['text'], vector_size=100, \n",
    "               window=5, min_count=1, workers=4)\n",
    "\n",
    "# calculate average vector for each text \n",
    "sentence_vect_arr = np.zeros((len(sexism_df_w2v['text']), 100))\n",
    "\n",
    "for i in range(len(sentence_vect_arr)):\n",
    "    word_vectors = [w2v.wv[word] for word in sexism_df_w2v['text'][i]]\n",
    "    sentence_vector = np.mean(word_vectors, axis=0)\n",
    "    sentence_vect_arr[i] = sentence_vector\n",
    "    \n",
    "# normalize values so everything is positive\n",
    "sentence_vect_df = pd.DataFrame(sentence_vect_arr, columns=[f'dim{i}' for i in range(1, 101)])\n",
    "sentence_vect_df_min = sentence_vect_df.min().min()\n",
    "sentence_vect_df = sentence_vect_df + abs(sentence_vect_df_min)\n",
    "\n",
    "# add vectorized data to dataset\n",
    "sexism_df_w2v = pd.concat([sexism_df_w2v, sentence_vect_df], axis=1)\n",
    "\n",
    "sexism_df_w2v.head()"
   ]
  },
