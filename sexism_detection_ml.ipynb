   "source": [
    "# TEST KNC\n",
    "\n",
    "import matplotlib.pyplot as plt\n",
    "from sklearn.model_selection import cross_val_score \n",
    "\n",
    "k_arr = range(1, 16)\n",
    "mean_cvs_arr = []\n",
    "\n",
    "for k in k_arr:\n",
    "    knc = KNeighborsClassifier(n_neighbors=k)\n",
    "    knc.fit(x_train_tfidf, y_train_tfidf)\n",
    "    y_p = knc.predict(x_test_tfidf)\n",
    "    \n",
    "    test = classification_report(y_test_tfidf, y_p, output_dict=True)\n",
    "    mean_cvs_arr.append(test['weighted avg']['f1-score'])\n",
    "    \n",
    "plt.plot(k_arr, mean_cvs_arr)\n",
    "plt.title(\"K vs Mean Accuracy\")\n",
    "plt.xlabel(\"K\")\n",
    "plt.ylabel(\"Mean Accuracy\")\n",
    "plt.show\n",
    "\n",
    "highest_k = np.argmax(mean_cvs_arr)\n",
    "highest_mean_accuracy = mean_cvs_arr[highest_k]\n",
    "\n",
    "print(f\"K = {highest_k + 1} had the highest mean accuracy of {highest_mean_accuracy}\")"
   ]
