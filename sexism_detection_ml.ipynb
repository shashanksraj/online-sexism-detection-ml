    "# open dataset\n",
    "sexism_df = pd.read_csv('edos_labelled_data.csv')\n",
    "\n",
    "# drop rewire_id column\n",
    "sexism_df = sexism_df.drop('rewire_id', axis=1)\n",
    "\n",
    "# remove emojis\n",
    "sexism_df = sexism_df.astype(str).apply(lambda x: x.str.encode('ascii', 'ignore').str.decode('ascii'))\n",
    "\n",
    "# convert text to lowercase\n",
    "sexism_df['text'] = sexism_df['text'].str.lower()\n",
    "\n",
    "# tokenization \n",
    "sexism_df['text'] = sexism_df['text'].apply(lambda x: word_tokenize(x))\n",
    "\n",
    "# remove punctuation\n",
    "stop_words = set(stopwords.words('english'))\n",
    "sexism_df['text'] = sexism_df['text'].apply(lambda tokens: \n",
    "                                            [word.strip(string.punctuation) for word in tokens \n",
    "                                             if word not in stop_words and word.strip(string.punctuation)])\n",
    "\n",
    "# remove stopwords\n",
    "sexism_df['text'] = sexism_df['text'].apply(lambda tokens: \n",
    "                                            [word for word in tokens if word not in stop_words])\n",
    "\n",
    "# lemmatization\n",
    "lemmatizer = WordNetLemmatizer()\n",
    "sexism_df['text'] = sexism_df['text'].apply(lambda tokens: \n",
    "                                            [lemmatizer.lemmatize(word) for word in tokens])\n",
    "\n",
    "# stemming\n",
    "#stemmer = PorterStemmer()\n",
    "#sexism_df['text'] = sexism_df['text'].apply(lambda tokens: \n",
    "#                                            [stemmer.stem(word) for word in tokens])\n",
    "\n",
    "# return text input to string\n",
    "sexism_df['text'] = sexism_df['text'].apply(lambda x: ' '.join(x))\n",
    "\n",
    "sexism_df.head()"
   ]
  },
