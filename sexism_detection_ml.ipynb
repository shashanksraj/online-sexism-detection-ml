    "# feature engineer data using TF-IDF\n",
    "\n",
    "# copy sexism_df dataset\n",
    "sexism_df_tfidf = sexism_df.copy()\n",
    "\n",
    "# rename column labels as to not have any duplicates later\n",
    "sexism_df_tfidf = sexism_df_tfidf.rename(columns={'text' : 'text_original', \n",
    "                                                 'label' : 'label_original',\n",
    "                                                 'split' : 'split_original'})\n",
    "\n",
    "# vectorize data\n",
    "tfidf_vectorizer = TfidfVectorizer()\n",
    "tfidf_matrix = tfidf_vectorizer.fit_transform(sexism_df_tfidf['text_original'])\n",
    "\n",
    "# add vectorized data to dataset\n",
    "tfidf = pd.DataFrame(tfidf_matrix.toarray(), columns=tfidf_vectorizer.get_feature_names_out())\n",
    "sexism_df_tfidf = pd.concat([sexism_df_tfidf, tfidf], axis=1)\n",
    "\n",
    "#print(tfidf[0])\n",
    "print(sexism_df_tfidf['nigeria'][0])\n",
    "#sexism_df_tfidf.head()\n",
    "sexism_df_tfidf.head()"
